# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===== DATABASE CONFIGURATION =====
# PostgreSQL (Primary Database)
POSTGRES_URL=postgresql://username:password@host:port/suraksha_setu
DB_NAME=suraksha_setu

# MongoDB (Optional - for future migration)
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/suraksha_setu

# ===== AI & API KEYS =====
# OpenAI API Key (for AI Chatbot)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Gemini AI (Backup/Alternative)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MOSDAC API Key (Indian Meteorological Data)
# Get from: https://www.mosdac.gov.in/
MOSDAC_API_KEY=your_mosdac_api_key_here

# OpenWeather API Key (Weather & AQI)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WAQI API Key (Air Quality)
# Get from: https://aqicn.org/api/
WAQI_API_KEY=your_waqi_api_key_here

# ===== SECURITY =====
SECRET_KEY=your_secret_key_change_in_production_min_32_chars
JWT_SECRET=your_jwt_secret_key_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== PUSH NOTIFICATIONS (VAPID Keys) =====
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key); print(v.public_key)"
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_CLAIMS_EMAIL=mailto:admin@surakshasetu.com

# ===== OPTIONAL SERVICES =====
# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Twilio (SMS/WhatsApp Alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===== SERVER CONFIGURATION =====
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://your-frontend-url.onrender.com

# ===== FEATURE FLAGS =====
ENABLE_AI_INSIGHTS=true
ENABLE_REAL_TIME_DATA=true
ENABLE_PUSH_NOTIFICATIONS=true
