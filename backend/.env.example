# Backend Environment Variables Template
# Copy these to Render's Environment Variables section or create a .env file locally

# MongoDB Configuration
MONGO_URL=your_mongodb_connection_string
DB_NAME=suraksha_setu

# WAQI (World Air Quality Index) API Key
# Get your FREE API key at: https://aqicn.org/data-platform/token/
# Without a real key, the demo token returns Shanghai data for all locations
WAQI_API_KEY=demo

# Gemini AI API Key (optional - using rule-based insights by default)
GEMINI_API_KEY=your_gemini_api_key

# Security
JWT_SECRET=your_jwt_secret_key_here

# CORS Settings
CORS_ORIGINS=https://your-frontend-url.onrender.com,http://localhost:3000
